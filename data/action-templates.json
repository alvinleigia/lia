{
  "templates": [
    {
      "key": "spa_service_booking",
      "name": "Spa Service Booking",
      "description": "Creates a spa booking action that collects category, service, preferred schedule, and guest contact details.",
      "businessTypes": ["spa", "resort", "wellness"],
      "action": {
        "name": "Book Spa Service",
        "description": "Guides guests through requesting a spa appointment by collecting their service category, service choice, preferred schedule, and contact information.",
        "status": "active",
        "triggerPhrases": [
          "book spa",
          "spa appointment",
          "book massage",
          "schedule massage"
        ],
        "settings": {
          "templateKey": "spa_service_booking",
          "catalogId": "cat_spa_services"
        }
      },
      "steps": [
        {
          "sortOrder": 1,
          "stepType": "collect_input",
          "fieldKey": "serviceCategoryId",
          "label": "Service Category",
          "prompt": "Which spa service category would you like?",
          "inputType": "text",
          "isRequired": true,
          "options": [],
          "settings": {
            "sourceType": "catalog_categories",
            "sourceConfig": {
              "catalogId": "cat_spa_services"
            }
          }
        },
        {
          "sortOrder": 2,
          "stepType": "collect_input",
          "fieldKey": "serviceItemId",
          "label": "Service",
          "prompt": "Which service would you like?",
          "inputType": "text",
          "isRequired": true,
          "options": [],
          "settings": {
            "sourceType": "catalog_items",
            "sourceConfig": {
              "catalogId": "cat_spa_services",
              "filterByField": "serviceCategoryId"
            }
          }
        },
        {
          "sortOrder": 3,
          "stepType": "collect_input",
          "fieldKey": "preferredDate",
          "label": "Preferred Date",
          "prompt": "What date would you prefer for the spa appointment?",
          "inputType": "date",
          "isRequired": true,
          "options": [],
          "settings": {}
        },
        {
          "sortOrder": 4,
          "stepType": "collect_input",
          "fieldKey": "preferredTime",
          "label": "Preferred Time",
          "prompt": "What time would you prefer?",
          "inputType": "time",
          "isRequired": true,
          "options": [],
          "settings": {}
        },
        {
          "sortOrder": 5,
          "stepType": "collect_input",
          "fieldKey": "guestName",
          "label": "Guest Name",
          "prompt": "What name should we put on the request?",
          "inputType": "text",
          "isRequired": true,
          "options": [],
          "settings": {}
        },
        {
          "sortOrder": 6,
          "stepType": "collect_input",
          "fieldKey": "guestEmail",
          "label": "Guest Email",
          "prompt": "What email should we use to contact you?",
          "inputType": "email",
          "isRequired": true,
          "options": [],
          "settings": {}
        },
        {
          "sortOrder": 7,
          "stepType": "collect_input",
          "fieldKey": "guestPhone",
          "label": "Guest Phone",
          "prompt": "What phone number should we use if the spa team needs to reach you?",
          "inputType": "phone",
          "isRequired": true,
          "options": [],
          "settings": {}
        },
        {
          "sortOrder": 8,
          "stepType": "confirmation",
          "fieldKey": null,
          "label": "Confirm Request",
          "prompt": "Please review your spa appointment request before we save it.",
          "inputType": null,
          "isRequired": false,
          "options": [],
          "settings": {}
        },
        {
          "sortOrder": 9,
          "stepType": "submit",
          "fieldKey": null,
          "label": "Submit Request",
          "prompt": "Submitting your spa appointment request.",
          "inputType": null,
          "isRequired": false,
          "options": [],
          "settings": {}
        }
      ]
    },
